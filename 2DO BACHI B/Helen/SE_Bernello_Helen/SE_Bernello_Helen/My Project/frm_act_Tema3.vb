    Private Sub btn_comprobar_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles btn_comprobar.Click
        If suma = 4 Then
            chk_2.Visible = True
            chk_2.Checked = True
        End If
        If resta = 5 Then
            chk_3.Visible = True
            chk_3.Checked = True
        End If
        If combinadas = 10 Then
            chk_4.Visible = True
            chk_4.Checked = True
        End If
        If corchetes = 8 Then
            chk_1.Visible = True
            chk_1.Checked = True
        End If
        If palabras = 1 Then
            MsgBox("Te faltan 3 palabras por encontrar", MsgBoxStyle.Exclamation, "Palabra encontrada")
        ElseIf palabras = 2 Then
            MsgBox("Te faltan 2 palabras por encontrar", MsgBoxStyle.Exclamation, "Palabra encontrada")
        ElseIf palabras = 3 Then
            MsgBox("Te faltan 1 palabras por encontrar", MsgBoxStyle.Exclamation, "Palabra encontrada")
        ElseIf palabras = 4 Then
            MsgBox("Buen Trabajo", MsgBoxStyle.OkOnly, "Palabra encontrada")
            Button1.Visible = True
            Button3.Visible = True
        Else
            MsgBox("Te faltan 4 palabras por encontrar", MsgBoxStyle.Exclamation, "Palabra encontrada")
        End If
    End Sub

    Private Sub frm_act_Tema3_Load(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles MyBase.Load
        Button1.Visible = False
        Button3.Visible = False
    End Sub
